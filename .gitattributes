# Normalize line endings to LF in the repository.
# Working tree files on Windows/WSL2 may use CRLF -- that is fine.
* text=auto eol=lf

# Ensure these are always LF (scripts, configs)
*.py text eol=lf
*.dart text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.sh text eol=lf
*.bat text eol=crlf

# Binary files -- do not touch
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.zip binary
*.tar.gz binary
*.exe binary
