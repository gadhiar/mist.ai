# =============================================================================
# MIST.AI Environment Configuration
# =============================================================================
# Copy this file to .env and update values as needed.
# All values shown are defaults.

# -----------------------------------------------------------------------------
# Neo4j Configuration
# -----------------------------------------------------------------------------
NEO4J_URI=bolt://mist-neo4j:7687
# For native (non-Docker) mode: NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# -----------------------------------------------------------------------------
# LLM Backend
# -----------------------------------------------------------------------------
LLM_BACKEND=llamacpp              # "llamacpp" (llama-server) or "ollama" (fallback)
LLM_SERVER_URL=http://mist-llm:8080  # Docker internal URL
# For native (non-Docker) mode:
# LLM_SERVER_URL=http://localhost:8080
MODEL=qwen2.5:7b-instruct

# Model files (host paths)
MODELS_DIR=./models               # Host directory with GGUF files
LLM_MODEL_FILE=Qwen2.5-14B-Instruct-Q4_K_M.gguf
LLM_CTX_SIZE=16384
LLM_TEMPERATURE=0.0

# -----------------------------------------------------------------------------
# Embedding Configuration
# -----------------------------------------------------------------------------
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
EMBEDDING_DEVICE=cpu

# -----------------------------------------------------------------------------
# Knowledge Integration
# -----------------------------------------------------------------------------
ENABLE_KNOWLEDGE_INTEGRATION=true
ONTOLOGY_VERSION=1.0.0
ENABLE_VERSIONING=true
ENABLE_PROVENANCE=true

# -----------------------------------------------------------------------------
# Persistent Data Paths (container mode)
# -----------------------------------------------------------------------------
# These override defaults that resolve to container-local paths.
# In native mode, comment these out to use defaults (~/.mist/, data/).
EVENT_STORE_DB_PATH=/app/data/event_store.db
EVENT_STORE_AUDIO_DIR=/app/data/audio
VECTOR_STORE_DATA_DIR=/app/data/vector_store

# -----------------------------------------------------------------------------
# Voice Configuration
# -----------------------------------------------------------------------------
TTS_ENABLED=true
TTS_ENGINE=chatterbox
VOICE_PROFILE=friday

# -----------------------------------------------------------------------------
# TTS Configuration (Chatterbox Turbo)
# -----------------------------------------------------------------------------
TTS_EXAGGERATION=0.5
TTS_TEMPERATURE=0.8
TTS_CFG_WEIGHT=0.5

# -----------------------------------------------------------------------------
# Hugging Face Token (required for some model downloads)
# -----------------------------------------------------------------------------
# HF_TOKEN=hf_your_token_here

# -----------------------------------------------------------------------------
# Event Store (Layer 1)
# -----------------------------------------------------------------------------
EVENT_STORE_ENABLED=true
# EVENT_STORE_DB_PATH=       # Defaults to ~/.mist/event_store.db
# EVENT_STORE_AUDIO_DIR=     # Defaults to ~/.mist/audio/

# -----------------------------------------------------------------------------
# Auto-RAG Configuration
# -----------------------------------------------------------------------------
AUTO_INJECT_DOCS=true
AUTO_INJECT_LIMIT=3
AUTO_INJECT_THRESHOLD=0.4

# =============================================================================
# Knowledge System Enhancement Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Vector Store (K-02)
# -----------------------------------------------------------------------------
VECTOR_STORE_BACKEND=lancedb
VECTOR_STORE_DATA_DIR=data/vector_store
VECTOR_STORE_SIMILARITY_THRESHOLD=0.6
VECTOR_STORE_BATCH_SIZE=100
VECTOR_STORE_COLLECTION=mist_knowledge

# -----------------------------------------------------------------------------
# Ingestion Pipeline (K-03)
# -----------------------------------------------------------------------------
INGESTION_CHUNK_SIZE=512
INGESTION_CHUNK_OVERLAP=64
INGESTION_BATCH_SIZE=100
INGESTION_DEDUP_WINDOW_DAYS=30

# -----------------------------------------------------------------------------
# Extraction Config
# -----------------------------------------------------------------------------
EXTRACT_NODE_PROPERTIES=true
EXTRACT_REL_PROPERTIES=true
MIN_EXTRACTION_CONFIDENCE=0.5

# -----------------------------------------------------------------------------
# Extraction Enhancements (K-12)
# -----------------------------------------------------------------------------
SIGNIFICANCE_THRESHOLD=0.3
RATE_LIMIT_MAX_PER_MINUTE=30
DEDUP_SIMILARITY_THRESHOLD=0.95
DEDUP_CACHE_SIZE=200
DEDUP_CACHE_TTL_SECONDS=300

# -----------------------------------------------------------------------------
# Query Intent / Hybrid Retrieval (K-07/K-08)
# -----------------------------------------------------------------------------
QUERY_HYBRID_THRESHOLD=0.4
QUERY_CONFIDENCE_BASE=0.5
QUERY_CONFIDENCE_PER_MATCH=0.1
QUERY_MIN_CONFIDENCE=0.3
RRF_K=60
RRF_VECTOR_WEIGHT=0.5
RRF_GRAPH_WEIGHT=0.5
MAX_VECTOR_RESULTS=20
MAX_GRAPH_RESULTS=20

# -----------------------------------------------------------------------------
# Skill Derivation (K-11)
# -----------------------------------------------------------------------------
SKILL_MIN_SESSION_USES=3
SKILL_WINDOW_SIZE=50
SKILL_CAPABILITY_THRESHOLD=5
SKILL_LOOKBACK_DAYS=7
SKILL_SIMILARITY_THRESHOLD=0.7
SKILL_DERIVATION_ENABLED=true
